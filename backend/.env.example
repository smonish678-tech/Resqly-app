# Backend environment variables — copy this file to /app/backend/.env and fill in real values.
# DO NOT commit the real .env file.

# MongoDB (provided by your hosting platform)
MONGO_URL=mongodb://localhost:27017
DB_NAME=resqly_v1

# CORS — comma-separated origins, or * for dev
CORS_ORIGINS=*

# JWT signing secret — generate with: python -c "import secrets;print(secrets.token_urlsafe(64))"
JWT_SECRET=replace-with-a-long-random-string

# Hidden admin login password
ADMIN_PASSWORD=replace-with-a-strong-password

# Supabase Storage (server-side only — never expose service-role key in frontend)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-your-service-role-key
PUBLIC_BUCKETS=profile-images
